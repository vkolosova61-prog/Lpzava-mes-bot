# Copy this file to .env on the server and fill real values.
NODE_ENV=production

BOT_TOKEN=123456:replace_me
DUMP_CHANNEL_ID=-1001234567890
BOT_POLLING_ENABLED=true
API_PORT=3001
CORS_ORIGIN=https://your-mini-app.example.com

TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=replace_me
TELEGRAM_PHONE_NUMBER=+380000000000
TELEGRAM_SESSION=replace_me_after_npm_run_auth

DATABASE_URL=postgresql://postgres:password@host:5432/railway
DATABASE_SSL=false

S3_BUCKET=your-railway-bucket-name
S3_ENDPOINT=https://your-railway-bucket-endpoint
S3_REGION=auto
S3_ACCESS_KEY_ID=replace_me
S3_SECRET_ACCESS_KEY=replace_me
S3_FORCE_PATH_STYLE=true

VITE_API_BASE_URL=https://your-api.example.com
