{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/user-client/Dockerfile"
  },
  "deploy": {
    "startCommand": "bun apps/user-client/src/index.ts",
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 10
  }
}
